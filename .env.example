# ─────────────────────────────────────────────────────────────────────────────
#  Bus Tracker — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Flask environment: 'production' enables secure cookies and disables debug
FLASK_ENV=production

# Secret key for session signing — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-set-in-env

# ── Database ──────────────────────────────────────────────────────────────────

# SQLite (simple, no extra service needed)
# DATABASE_URL=sqlite:///bustrack.db

# PostgreSQL (recommended for production)
DATABASE_URL=postgresql://bususer:buspass@localhost:5432/bustrack

# PostgreSQL credentials (used by docker-compose.yml)
DB_NAME=bustrack
DB_USER=bususer
DB_PASS=buspass

# ── Optional ──────────────────────────────────────────────────────────────────

# Port to expose (default: 5000)
# PORT=5000
